# Meta Graph API credentials for auto-posting
# See README-autopost.md for how to get these values

# Long-lived Page Access Token (valid ~60 days, must be refreshed)
META_PAGE_ACCESS_TOKEN=

# Facebook Page ID (numeric)
META_PAGE_ID=

# Instagram Business Account ID (numeric, linked to the Facebook Page)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Cloudflare R2 (for IG Reels video hosting)
